{
  "$comment": "generated by nel-contracts projector 1",
  "$id": "urn:nel:contracts:v1:seam-receipt",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "The kernel-authored acknowledgement returned by ``submit_intent``.\n\nCarries no credential and no live handle. ``authority``/``attestation`` are only\ntrustworthy after out-of-process kernel verification; a ``SealedSeam`` or world-built\ninstance carries ``authority=\"projection\"`` / ``attestation=\"unsigned\"`` and is untrusted.",
  "properties": {
    "approval_request_id": {
      "anyOf": [
        {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Request Id"
    },
    "attestation": {
      "default": "unsigned",
      "title": "Attestation",
      "type": "string"
    },
    "authority": {
      "default": "projection",
      "enum": [
        "projection",
        "kernel",
        "operator"
      ],
      "title": "Authority",
      "type": "string"
    },
    "block_reason": {
      "anyOf": [
        {
          "examples": [
            "external_publish_or_public_repo_mutation",
            "history_rewrite",
            "irreversible_architecture_decision_without_adr_precedent",
            "irreversible_destructive_migration",
            "legal_or_license_decision",
            "main_merge",
            "missing_credentials_or_permissions",
            "payment_or_purchase",
            "pii_storage_policy_change"
          ],
          "title": "GateClass",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Block Reason"
    },
    "decision_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Decision Ref"
    },
    "intent_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Intent Id",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "run_id": {
      "anyOf": [
        {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "state": {
      "examples": [
        "accepted",
        "blocked",
        "pending",
        "rejected",
        "unavailable"
      ],
      "title": "SubmissionState",
      "type": "string"
    },
    "work_item_id": {
      "anyOf": [
        {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Work Item Id"
    }
  },
  "required": [
    "intent_id",
    "state",
    "issued_at"
  ],
  "title": "SeamReceipt",
  "type": "object"
}
