{
  "$comment": "generated from pinned pydantic + type-level overrides, guarded by generate-and-diff (nel-contracts projector 1); a fuller hand-controlled projection layer is deferred (K-phase)",
  "$id": "urn:nel:contracts:v1:workflow-run",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "The neutral, ADVISORY (per ADR-0014 D3) projection of a bounded resumable execution.\n\nA world/Pantheon ``WorkflowRun`` is an OUTWARD projection of kernel truth: no ``WorkflowRun``\nevent may satisfy, mutate, or unblock a kernel gate. Kernel-only concerns — budgets, timeouts,\nactive-time intervals — are intentionally absent from this neutral shape.",
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "definition_id": {
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$",
      "title": "Definition Id",
      "type": "string"
    },
    "node_states": {
      "additionalProperties": {
        "examples": [
          "blocked",
          "cancelled",
          "capturing",
          "completed",
          "delivering",
          "failed",
          "planned",
          "reviewing",
          "revising",
          "running",
          "verifying"
        ],
        "type": "string"
      },
      "title": "Node States",
      "type": "object"
    },
    "projection_sequence": {
      "minimum": 1,
      "title": "Projection Sequence",
      "type": "integer"
    },
    "run_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Run Id",
      "type": "string"
    },
    "status": {
      "examples": [
        "blocked",
        "cancelled",
        "capturing",
        "completed",
        "delivering",
        "failed",
        "planned",
        "reviewing",
        "revising",
        "running",
        "verifying"
      ],
      "title": "WorkStatus",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "work_item_ref": {
      "pattern": "^[a-z0-9][a-z0-9-]{0,127}$",
      "title": "Work Item Ref",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "definition_id",
    "work_item_ref",
    "status",
    "projection_sequence",
    "created_at",
    "updated_at"
  ],
  "title": "WorkflowRun",
  "type": "object"
}
