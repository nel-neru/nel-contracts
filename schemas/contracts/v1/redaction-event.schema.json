{
  "$comment": "generated by nel-contracts projector 1",
  "$id": "urn:nel:contracts:v1:redaction-event",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A typed redaction record that carries **no** secret bytes and no secret-derived digest.\n\nUnsafe or unparseable secret-bearing payloads are discarded and represented by one of\nthese. It records only the *location* (``redacted_key_path``) and *reason*, never the\nredacted content. ``extra=\"forbid\"`` (via ``StrictModel``) structurally prevents smuggling\na ``secret``/``content`` field into the record.",
  "properties": {
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "placeholder": {
      "const": "[REDACTED]",
      "default": "[REDACTED]",
      "title": "Placeholder",
      "type": "string"
    },
    "reason": {
      "enum": [
        "secret_detected",
        "unparseable",
        "policy"
      ],
      "title": "Reason",
      "type": "string"
    },
    "redacted_key_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Redacted Key Path"
    },
    "redaction_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Redaction Id",
      "type": "string"
    }
  },
  "required": [
    "redaction_id",
    "reason",
    "occurred_at"
  ],
  "title": "RedactionEvent",
  "type": "object"
}
