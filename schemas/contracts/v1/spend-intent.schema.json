{
  "$comment": "generated from pinned pydantic + type-level overrides, guarded by generate-and-diff (nel-contracts projector 1); a fuller hand-controlled projection layer is deferred (K-phase)",
  "$defs": {
    "ClaimedActor": {
      "additionalProperties": false,
      "description": "An inbound, self-asserted actor carried on a ``WorkIntent``.\n\nEvery field is a claim. It is NOT an authorization input: the kernel re-derives the real\nactor from the authenticated channel identity (design §4). ``attestation_state`` is pinned\nto ``unattested`` so a public consumer cannot confuse it with a kernel-attested actor.",
      "properties": {
        "actor_kind": {
          "examples": [
            "claude_code",
            "codex",
            "game_engine",
            "github_actions",
            "http",
            "human",
            "mcp",
            "script"
          ],
          "title": "ActorKind",
          "type": "string"
        },
        "attestation_state": {
          "const": "unattested",
          "default": "unattested",
          "title": "Attestation State",
          "type": "string"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "is_advisory": {
          "default": true,
          "title": "Is Advisory",
          "type": "boolean"
        }
      },
      "required": [
        "actor_kind"
      ],
      "title": "ClaimedActor",
      "type": "object"
    }
  },
  "$id": "urn:nel:contracts:v1:spend-intent",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actor": {
      "$ref": "#/$defs/ClaimedActor"
    },
    "amount_minor": {
      "minimum": 0,
      "title": "Amount Minor",
      "type": "integer"
    },
    "currency": {
      "pattern": "^[A-Z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "intent_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Intent Id",
      "type": "string"
    },
    "kind": {
      "const": "spend",
      "default": "spend",
      "title": "Kind",
      "type": "string"
    },
    "payee": {
      "title": "Payee",
      "type": "string"
    },
    "submitted_at": {
      "format": "date-time",
      "title": "Submitted At",
      "type": "string"
    }
  },
  "required": [
    "intent_id",
    "actor",
    "submitted_at",
    "amount_minor",
    "currency",
    "payee"
  ],
  "title": "SpendIntent",
  "type": "object"
}
