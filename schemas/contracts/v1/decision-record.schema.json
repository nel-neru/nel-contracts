{
  "$comment": "generated by nel-contracts projector 1",
  "$defs": {
    "AttestedActor": {
      "additionalProperties": false,
      "description": "A kernel-attested actor carried on kernel-authored records. Trust requires verifying\n``attestation`` against the kernel — which the package cannot do (no key shipped).",
      "properties": {
        "actor_kind": {
          "examples": [
            "claude_code",
            "codex",
            "game_engine",
            "github_actions",
            "http",
            "human",
            "mcp",
            "script"
          ],
          "title": "ActorKind",
          "type": "string"
        },
        "attestation": {
          "$ref": "#/$defs/KernelAttestation"
        },
        "attestation_state": {
          "const": "kernel_attested",
          "default": "kernel_attested",
          "title": "Attestation State",
          "type": "string"
        }
      },
      "required": [
        "actor_kind",
        "attestation"
      ],
      "title": "AttestedActor",
      "type": "object"
    },
    "ClaimedActor": {
      "additionalProperties": false,
      "description": "An inbound, self-asserted actor carried on a ``WorkIntent``.\n\nEvery field is a claim. It is NOT an authorization input: the kernel re-derives the real\nactor from the authenticated channel identity (design §4). ``attestation_state`` is pinned\nto ``unattested`` so a public consumer cannot confuse it with a kernel-attested actor.",
      "properties": {
        "actor_kind": {
          "examples": [
            "claude_code",
            "codex",
            "game_engine",
            "github_actions",
            "http",
            "human",
            "mcp",
            "script"
          ],
          "title": "ActorKind",
          "type": "string"
        },
        "attestation_state": {
          "const": "unattested",
          "default": "unattested",
          "title": "Attestation State",
          "type": "string"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "is_advisory": {
          "default": true,
          "title": "Is Advisory",
          "type": "boolean"
        }
      },
      "required": [
        "actor_kind"
      ],
      "title": "ClaimedActor",
      "type": "object"
    },
    "KernelAttestation": {
      "additionalProperties": false,
      "description": "A kernel-authored attestation shape. The package ships **no** verification key, so a\nworld-built instance of this shape is unverifiable and therefore untrusted (design §0).",
      "properties": {
        "authority": {
          "const": "kernel",
          "default": "kernel",
          "title": "Authority",
          "type": "string"
        },
        "nonce": {
          "title": "Nonce",
          "type": "string"
        },
        "signature": {
          "title": "Signature",
          "type": "string"
        }
      },
      "required": [
        "nonce",
        "signature"
      ],
      "title": "KernelAttestation",
      "type": "object"
    }
  },
  "$id": "urn:nel:contracts:v1:decision-record",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "An append-only decision authored before any adapter dispatch.\n\nA world-built instance carries no authority: trust requires kernel verification the\npackage cannot perform (design §0). The human-only-gate check\n(``resolver`` must be a human for a human-gated ``allow``) is decided kernel-side; the\nshape-level :meth:`human_only_gate_respected` here is corroborating and non-authoritative.",
  "properties": {
    "approval_request_id": {
      "anyOf": [
        {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Request Id"
    },
    "authority": {
      "default": "projection",
      "enum": [
        "projection",
        "kernel",
        "operator"
      ],
      "title": "Authority",
      "type": "string"
    },
    "decided_at": {
      "format": "date-time",
      "title": "Decided At",
      "type": "string"
    },
    "decision": {
      "enum": [
        "allow",
        "block"
      ],
      "title": "Decision",
      "type": "string"
    },
    "decision_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Decision Id",
      "type": "string"
    },
    "gate": {
      "anyOf": [
        {
          "examples": [
            "external_publish_or_public_repo_mutation",
            "history_rewrite",
            "irreversible_architecture_decision_without_adr_precedent",
            "irreversible_destructive_migration",
            "legal_or_license_decision",
            "main_merge",
            "missing_credentials_or_permissions",
            "payment_or_purchase",
            "pii_storage_policy_change"
          ],
          "title": "GateClass",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Gate"
    },
    "resolver": {
      "anyOf": [
        {
          "$ref": "#/$defs/ClaimedActor"
        },
        {
          "$ref": "#/$defs/AttestedActor"
        }
      ],
      "title": "Resolver"
    }
  },
  "required": [
    "decision_id",
    "decision",
    "resolver",
    "decided_at"
  ],
  "title": "DecisionRecord",
  "type": "object"
}
