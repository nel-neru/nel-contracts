{
  "$comment": "generated by nel-contracts projector 1",
  "$defs": {
    "ContentIdentity": {
      "additionalProperties": false,
      "description": "A repo-agnostic identity for the content an intent acts on.\n\nAt least one identifier is required. For non-git intents the kernel persists the exact\nsubmitted payload immutably at submit time and recomputes ``content_digest`` over the\nstored copy, executing only against that stored copy (resolves the non-git TOCTOU\nfinding) — behavior documented here, enforced kernel-side.",
      "properties": {
        "commit_sha": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Commit Sha"
        },
        "content_digest": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Digest"
        },
        "content_tree_oid": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Tree Oid"
        },
        "pr_head_sha": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pr Head Sha"
        }
      },
      "title": "ContentIdentity",
      "type": "object"
    }
  },
  "$id": "urn:nel:contracts:v1:approval-request",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A durable, async approval request. A gated category returns ``state=blocked`` plus an\n``approval_request_id`` — there is no separate approval port verb.",
  "properties": {
    "approval_request_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Approval Request Id",
      "type": "string"
    },
    "content_identity": {
      "anyOf": [
        {
          "$ref": "#/$defs/ContentIdentity"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "gate": {
      "examples": [
        "external_publish_or_public_repo_mutation",
        "history_rewrite",
        "irreversible_architecture_decision_without_adr_precedent",
        "irreversible_destructive_migration",
        "legal_or_license_decision",
        "main_merge",
        "missing_credentials_or_permissions",
        "payment_or_purchase",
        "pii_storage_policy_change"
      ],
      "title": "GateClass",
      "type": "string"
    },
    "intent_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Intent Id",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "state": {
      "default": "open",
      "enum": [
        "open",
        "resolved"
      ],
      "title": "State",
      "type": "string"
    }
  },
  "required": [
    "approval_request_id",
    "gate",
    "intent_id",
    "requested_at"
  ],
  "title": "ApprovalRequest",
  "type": "object"
}
