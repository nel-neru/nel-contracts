{
  "$comment": "generated from pinned pydantic + type-level overrides, guarded by generate-and-diff (nel-contracts projector 1); a fuller hand-controlled projection layer is deferred (K-phase)",
  "$defs": {
    "ClaimedActor": {
      "additionalProperties": false,
      "description": "An inbound, self-asserted actor carried on a ``WorkIntent``.\n\nEvery field is a claim. It is NOT an authorization input: the kernel re-derives the real\nactor from the authenticated channel identity (design §4). ``attestation_state`` is pinned\nto ``unattested`` so a public consumer cannot confuse it with a kernel-attested actor.",
      "properties": {
        "actor_kind": {
          "examples": [
            "claude_code",
            "codex",
            "game_engine",
            "github_actions",
            "http",
            "human",
            "mcp",
            "script"
          ],
          "title": "ActorKind",
          "type": "string"
        },
        "attestation_state": {
          "const": "unattested",
          "default": "unattested",
          "title": "Attestation State",
          "type": "string"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "is_advisory": {
          "default": true,
          "title": "Is Advisory",
          "type": "boolean"
        }
      },
      "required": [
        "actor_kind"
      ],
      "title": "ClaimedActor",
      "type": "object"
    },
    "ContentIdentity": {
      "additionalProperties": false,
      "description": "A repo-agnostic identity for the content an intent acts on.\n\nAt least one identifier is required. For non-git intents the kernel persists the exact\nsubmitted payload immutably at submit time and recomputes ``content_digest`` over the\nstored copy, executing only against that stored copy (resolves the non-git TOCTOU\nfinding) — behavior documented here, enforced kernel-side.",
      "properties": {
        "commit_sha": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Commit Sha"
        },
        "content_digest": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Digest"
        },
        "content_tree_oid": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Tree Oid"
        },
        "pr_head_sha": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pr Head Sha"
        }
      },
      "title": "ContentIdentity",
      "type": "object"
    },
    "GitDeliveryExtension": {
      "additionalProperties": false,
      "description": "Git-specific delivery fields, kept out of the neutral ``DeliveryIntent`` base so the\ncore stays repo-agnostic (resolves the \"git baked into the neutral package\" finding).",
      "properties": {
        "base_ref": {
          "title": "Base Ref",
          "type": "string"
        },
        "content_tree_oid": {
          "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$",
          "title": "Content Tree Oid",
          "type": "string"
        },
        "git_operation": {
          "title": "Git Operation",
          "type": "string"
        }
      },
      "required": [
        "content_tree_oid",
        "base_ref",
        "git_operation"
      ],
      "title": "GitDeliveryExtension",
      "type": "object"
    }
  },
  "$id": "urn:nel:contracts:v1:delivery-intent",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Deliver content bound by identity. Git specifics live in ``git`` (a specialization),\nnot in the neutral base.",
  "properties": {
    "actor": {
      "$ref": "#/$defs/ClaimedActor"
    },
    "content_identity": {
      "$ref": "#/$defs/ContentIdentity"
    },
    "git": {
      "anyOf": [
        {
          "$ref": "#/$defs/GitDeliveryExtension"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "intent_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Intent Id",
      "type": "string"
    },
    "kind": {
      "const": "delivery",
      "default": "delivery",
      "title": "Kind",
      "type": "string"
    },
    "operation": {
      "examples": [
        "deliver",
        "publish_artifact",
        "push"
      ],
      "title": "DeliveryOperation",
      "type": "string"
    },
    "submitted_at": {
      "format": "date-time",
      "title": "Submitted At",
      "type": "string"
    }
  },
  "required": [
    "intent_id",
    "actor",
    "submitted_at",
    "content_identity",
    "operation"
  ],
  "title": "DeliveryIntent",
  "type": "object"
}
