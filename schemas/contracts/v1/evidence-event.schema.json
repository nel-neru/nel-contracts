{
  "$comment": "generated from pinned pydantic + type-level overrides, guarded by generate-and-diff (nel-contracts projector 1); a fuller hand-controlled projection layer is deferred (K-phase)",
  "$id": "urn:nel:contracts:v1:evidence-event",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A neutral, digest-bound evidence record.\n\n``content_digest`` binds to the produced artifact by digest, never by embedding its bytes.",
  "properties": {
    "classification": {
      "examples": [
        "adjudication",
        "capture",
        "ledger",
        "review",
        "verification"
      ],
      "title": "EvidenceClassification",
      "type": "string"
    },
    "content_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Digest",
      "type": "string"
    },
    "evidence_id": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "title": "Evidence Id",
      "type": "string"
    },
    "produced_at": {
      "format": "date-time",
      "title": "Produced At",
      "type": "string"
    },
    "summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Summary"
    }
  },
  "required": [
    "evidence_id",
    "classification",
    "content_digest",
    "produced_at"
  ],
  "title": "EvidenceEvent",
  "type": "object"
}
