# Normalize line endings to LF in the blob. The editing environment writes CRLF on Windows;
# `* text=auto` guarantees committed blobs are LF so cross-platform CI stays byte-identical.
* text=auto

*.md text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Golden canonical byte-fixtures are exact bytes (no line endings); treat them as binary so
# nothing ever normalizes or diffs them.
conformance/fixtures/canonical/*.bytes binary
